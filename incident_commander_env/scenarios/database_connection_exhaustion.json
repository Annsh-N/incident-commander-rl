{
  "id": "database-connection-exhaustion",
  "title": "Application pool exhaustion driving database connection failures",
  "description": "Checkout traffic spikes into a connection-pool regression. App nodes exhaust database connections and throw 5xxs. Restarting the database is unsafe and does not solve the root cause.",
  "severity": "sev1",
  "ground_truth_root_cause_id": "checkout_pool_limit_too_low_under_burst_traffic",
  "services": [
    {"name": "checkout-service", "description": "Checkout API.", "dependencies": ["orders-db", "auth-service"], "owner": "payments", "initial_replicas": 6},
    {"name": "orders-db", "description": "Primary orders database.", "dependencies": [], "owner": "db", "initial_replicas": 1},
    {"name": "auth-service", "description": "Session and token service.", "dependencies": [], "owner": "identity", "initial_replicas": 3}
  ],
  "timeline_events": [
    {
      "step": 0,
      "alerts": [
        {"id": "alert-db-conn", "service": "orders-db", "signal": "db_conn > 90"},
        {"id": "alert-checkout-5xx", "service": "checkout-service", "signal": "error_rate > 5%"}
      ],
      "messages": [
        {"ts_step": 0, "sender": "traffic-bot", "text": "Promo campaign traffic is above forecast."}
      ]
    },
    {
      "step": 2,
      "messages": [
        {"ts_step": 2, "sender": "support", "text": "Checkout returns intermittent 500s."}
      ]
    }
  ],
  "evidence": {
