    "deploy_history": [
      {"service": "checkout-api", "step": 0, "from_version": "v51", "to_version": "v52", "author": "deploy-bot"}
    ],
    "config_diffs": [
      {
        "service": "checkout-api",
        "from_version": "v51",
        "to_version": "v52",
        "diff": [
          {"key": "RECOMMENDATION_CACHE_SIZE", "from": "256", "to": "1024"}
        ]
      }
    ],
    "trace_samples": [
      {
        "service": "checkout-api",
        "trace_id": "trace-memory-001",
        "spans": [
          {"service": "checkout-api", "operation": "POST /checkout", "duration_ms": 1410, "status": "error"},
          {"service": "recommendation-engine", "operation": "GET /upsell", "duration_ms": 91, "status": "ok"}
