        "error": "worker restarted after out of memory",
        "duration_ms": 1410
      }
    ],
    "runbook_snippets": {
      "checkout-api": {
        "triage": ["Check memory growth after recent deploys.", "OOM kills after deploy usually mean rollback is safer than blind restarts."],
        "mitigation": ["Rollback the leaking build.", "A restart can buy time but will not remove the leak."],
        "verification": ["Confirm memory_usage and error_rate fall after rollback."]
      }
    },
    "help_responses": {
      "db": "DB is healthy and not saturated.",
      "network": "No network anomaly detected.",
      "pricing": "Pricing is not implicated in the memory pressure.",
