        "memory_usage": {"degraded": [78, 84, 89, 93, 96, 97, 97], "stabilized": [72, 64, 58, 54, 52]},
        "error_rate": {"degraded": [2.8, 3.9, 5.1, 6.2, 6.5, 6.4, 6.2], "stabilized": [2.6, 1.8, 1.1, 0.8, 0.8]},
        "p95_latency": {"degraded": [980, 1110, 1260, 1390, 1450, 1430, 1400], "stabilized": [900, 660, 540, 490, 470]},
        "cpu": {"degraded": [49, 50, 52, 53, 54, 54, 53], "stabilized": [49, 48, 47, 46, 46]}
      },
      "recommendation-engine": {
        "cpu": {"degraded": [46, 46, 47, 47, 47, 46, 46], "stabilized": [46, 46, 45, 45, 45]}
      }
