{
  "id": "memory-leak-after-deploy",
  "title": "Memory leak introduced by recent checkout deployment",
  "description": "A new checkout build leaks memory under steady load. CPU stays moderate, but memory climbs until OOM kills start. Restarting alone buys little time unless the bad build is removed.",
  "severity": "sev1",
  "ground_truth_root_cause_id": "checkout_memory_leak_after_v52_deploy",
  "services": [
    {"name": "checkout-api", "description": "Checkout frontend API.", "dependencies": ["recommendation-engine"], "owner": "payments", "initial_replicas": 6},
    {"name": "recommendation-engine", "description": "Recommendation sidecar dependency.", "dependencies": [], "owner": "ml", "initial_replicas": 4},
    {"name": "orders-db", "description": "Orders database.", "dependencies": [], "owner": "db", "initial_replicas": 1}
  ],
  "timeline_events": [
    {
      "step": 0,
      "alerts": [
        {"id": "alert-checkout-memory", "service": "checkout-api", "signal": "memory_usage > 90"},
        {"id": "alert-checkout-oom", "service": "checkout-api", "signal": "oom_kill_count > 0"}
      ],
      "messages": [
        {"ts_step": 0, "sender": "deploy-bot", "text": "checkout-api v52 rollout completed an hour ago."}
      ]
    },
    {
      "step": 2,
      "messages": [
        {"ts_step": 2, "sender": "support", "text": "Users report checkout failures that recover briefly after pod restarts."}
      ]
    }
  ],
