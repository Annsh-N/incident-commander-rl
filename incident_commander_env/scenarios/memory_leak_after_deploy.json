  "patch_ids": {"checkout-api": []},
  "feature_flags": {"recommendation_cache_v2": true},
  "deploy_versions": {"checkout-api": "v52", "recommendation-engine": "v8", "orders-db": "db-2026-03-11"},
  "config_versions": {"checkout-api": "v52", "recommendation-engine": "v8", "orders-db": "db-2026-03-11"},
  "allowed_mitigations": ["rollback_checkout_v52_to_v51"],
  "safe_mitigations": ["rollback_checkout_v52_to_v51", "restart_checkout_service"],
