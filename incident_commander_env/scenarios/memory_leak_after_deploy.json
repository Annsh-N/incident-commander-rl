  "all_mitigations": ["rollback_checkout_v52_to_v51", "restart_checkout_service", "restart_database", "purge_queue"],
  "mitigation_rules": [
    {"mitigation_id": "rollback_checkout_v52_to_v51", "action_type": "rollback_deploy", "args_match": {"service": "checkout-api", "from_version": "v52", "to_version": "v51"}, "causal": true},
    {"mitigation_id": "restart_checkout_service", "action_type": "restart_service", "args_match": {"service": "checkout-api"}, "causal": false},
    {"mitigation_id": "restart_database", "action_type": "restart_service", "args_match": {"service": "orders-db"}, "causal": false, "forbidden": true}
  ],
  "causal_action_sets": [["rollback_checkout_v52_to_v51"]],
  "resolution_rubric": {
    "required_evidence_flags": ["saw_deploy", "saw_key_log"],
    "required_updates": [{"template_id": "status", "audience": "internal"}, {"template_id": "resolved", "audience": "internal"}],
    "required_verification": [
      {"service": "checkout-api", "metric": "memory_usage", "target": 70.0, "window_steps": 1},
      {"service": "checkout-api", "metric": "error_rate", "target": 2.5, "window_steps": 1}
    ],
    "min_investigation_categories": 2,
    "create_incident_by": 3
  },
  "evidence_markers": {
    "key_log_terms": ["OOM killer", "allocation failure"],
    "deploy_service": "checkout-api",
    "deploy_to_version": "v52",
    "config_keys": ["RECOMMENDATION_CACHE_SIZE"],
    "trace_error_terms": ["out of memory"]
  }
