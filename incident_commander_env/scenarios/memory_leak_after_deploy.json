    "logs": {
      "checkout-api": [
        {"step": 0, "service": "checkout-api", "level": "INFO", "message": "Booting checkout-api version=v52"},
        {"step": 1, "service": "checkout-api", "level": "WARN", "message": "heap usage climbed above 88% after 6 minutes"},
        {"step": 2, "service": "checkout-api", "level": "ERROR", "message": "process killed by OOM killer after allocation failure"},
        {"step": 2, "service": "checkout-api", "level": "WARN", "message": "recommendation-engine latency stable at 90ms"}
      ]
